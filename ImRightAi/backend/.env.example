# 백엔드 기본 실행값과 Flash-Lite 고정 운영 설정을 정의한다.
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
JWT_SECRET=replace-this-with-a-long-random-secret
GEMINI_API_KEY=replace-this-with-your-gemini-api-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-this-with-your-service-role-key
# 생성과 판정 모두 Flash-Lite를 사용하고,
# 실패 복구는 모델 변경이 아니라 repair 또는 고정 fallback으로 처리한다.
GENERATION_MODEL=gemini-2.5-flash-lite
JUDGE_MODEL=gemini-2.5-flash-lite
ADS_RETRY_ENABLED=true
MAX_RETRY_PER_DAY=0
MAX_OUTPUT_TOKENS_OPENING=140
MAX_OUTPUT_TOKENS_REBUTTAL=140
MAX_OUTPUT_TOKENS_JUDGE=120
REQUEST_TIMEOUT_MS=12000
KST_TIMEZONE=Asia/Seoul
